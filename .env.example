# AgentVoli — chiavi API per il travel planner
# Copia in `.env` e riempi solo quelle che ti servono.
# Convenzioni: lascia VUOTO ciò che non usi, NON committare `.env`.

# ─────────────────────────────────────────────────────────────────────────────
#  VOLI
# ─────────────────────────────────────────────────────────────────────────────
# fli scrapa Google Flights direttamente: NESSUNA chiave richiesta.

# ─────────────────────────────────────────────────────────────────────────────
#  POI / RISTORANTI / GEOCODING — senza carta di credito
# ─────────────────────────────────────────────────────────────────────────────

# Geoapify — 3.000 req/giorno gratis, no carta
# Signup: https://myprojects.geoapify.com/register
GEOAPIFY_API_KEY=

# OpenTripMap — 5.000 req/giorno gratis, no carta
# Signup: https://opentripmap.io/product
OPENTRIPMAP_API_KEY=

# Foursquare Places — 950 req/giorno gratis, no carta
# Signup: https://docs.foursquare.com/developer/reference/personalization-apis-authentication
FOURSQUARE_API_KEY=

# Nominatim (OpenStreetMap) — geocoding gratis, no key, 1 req/sec
# User-Agent obbligatorio: metti la TUA email per essere contattabile in caso di abuso
NOMINATIM_USER_AGENT=AgentVoli/1.0 (your-email@example.com)

# ─────────────────────────────────────────────────────────────────────────────
#  METEO / VALUTE / DATI PAESE — completamente gratis, no key
# ─────────────────────────────────────────────────────────────────────────────
# Open-Meteo: https://api.open-meteo.com/v1/forecast?...     (nessuna chiave)
# open.er-api.com: https://open.er-api.com/v6/latest/EUR     (nessuna chiave)
# REST Countries: https://restcountries.com/v3.1/name/...    (nessuna chiave)

# ─────────────────────────────────────────────────────────────────────────────
#  EVENTI
# ─────────────────────────────────────────────────────────────────────────────

# Ticketmaster Discovery — 5.000 req/giorno gratis, no carta
# Signup: https://developer-acct.ticketmaster.com/user/register
TICKETMASTER_API_KEY=

# Eventbrite — tier free rate-limited
# Signup: https://www.eventbrite.com/platform/api
EVENTBRITE_PRIVATE_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
#  IMMAGINI DESTINAZIONE
# ─────────────────────────────────────────────────────────────────────────────

# Unsplash — 50 req/h demo, 5.000 req/h dopo approvazione
# Signup: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pexels — illimitato, no carta
# Signup: https://www.pexels.com/api/
PEXELS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
#  GOOGLE — 200$/mese di credito, RICHIEDE CARTA DI CREDITO
# ─────────────────────────────────────────────────────────────────────────────
# Una sola chiave Google funziona per Places (New), Maps Directions,
# Distance Matrix, Geocoding. Abilita le API che ti servono nella console.
# Signup: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
#  HOTEL (no API gratis affidabile per i prezzi)
# ─────────────────────────────────────────────────────────────────────────────
# Booking.com Affiliate: ti dà link tracciati, NON un'API prezzi.
# Signup: https://admin.booking.com/?aid=...    (Partner Hub)
BOOKING_AFFILIATE_ID=

# ─────────────────────────────────────────────────────────────────────────────
#  LLM ORCHESTRATORE
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude — pay-per-use, crediti iniziali per nuovi account
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — tier gratuito generoso
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq — tier gratuito (Llama / Mixtral), velocissimo
# https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — pay-per-use
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
